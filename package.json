{
  "name": "@open-assets/open-assets",
  "version": "0.1.12",
  "description": "Dev server and export tool for app screenshots, icons, and logos. Like Storybook for marketing assets.",
  "type": "module",
  "bin": {
    "open-assets": "bin/open-assets.mjs"
  },
  "files": [
    "bin/",
    "lib/",
    "public/",
    "skills/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "screenshots",
    "app-store",
    "assets",
    "icons",
    "logos",
    "marketing",
    "storybook",
    "puppeteer",
    "open",
    "export",
    "xcode"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Parra-Inc/open-assets.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "assets": "node bin/open-assets.mjs render --all -o ./public/img",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "release": "./scripts/release.sh"
  },
  "homepage": "https://openassets.dev",
  "dependencies": {
    "commander": "^13.0.0",
    "open": "^10.0.0",
    "puppeteer": "^24.37.5"
  },
  "devDependencies": {
    "jest": "^30.3.0"
  }
}
